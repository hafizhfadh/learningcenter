{
    # Global options; Caddy already enables Automatic HTTPS by default.
    http_port 80
    https_port 443

    # HTTP/3
    servers {
        protocols h1 h2 h3
    }

    # Disable Caddy admin API in prod (safer)
    admin off

    # JSON logs to stdout (Docker-friendly)
    log {
        output stdout
        format json
        level INFO
    }
}

# Your primary site (APP_URL must be just the host, no scheme)
learning.csi-academy.id {

    encode zstd gzip

    # Static files first
    @static {
        path /build/* /assets/* *.ico *.css *.js *.png *.jpg *.jpeg *.svg *.webp *.gif *.woff *.woff2 *.ttf *.eot *.otf
    }
    handle @static {
        root * /app/public
        file_server
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # Laravel front controller
    handle {
        root * /app/public
        try_files {path} {path}/ /index.php?{query}
        php {
            root /app/public
        }
    }

    # Redirect http → https handled automatically by Caddy’s Auto HTTPS
}
