# =================================
# Laravel Production Environment
# =================================
# This file serves as a template for production environment variables.
# DO NOT commit actual production values to version control.
# Use container orchestration secrets or environment injection instead.

# Application
APP_NAME="LearningCenter"
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-domain.com
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Database Configuration (External PostgreSQL Cluster)
DB_CONNECTION=pgsql
DB_HOST=your_postgres_cluster_host.example.com
DB_PORT=5432
DB_DATABASE=learningcenter_production
DB_USERNAME=laravel_user
DB_PASSWORD=SECURE_DATABASE_PASSWORD
DB_SSLMODE=require

# Session & Cache
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.your-domain.com

CACHE_STORE=redis
CACHE_PREFIX=lc_prod

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=SECURE_REDIS_PASSWORD
REDIS_PORT=6379
REDIS_DB=0

# Queue
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USERNAME=POSTMARK_TOKEN
MAIL_PASSWORD=POSTMARK_TOKEN
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

# Postmark
POSTMARK_TOKEN=YOUR_POSTMARK_SERVER_TOKEN

# Logging
LOG_CHANNEL=stack
LOG_STACK=single,slack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Slack Logging (for critical errors)
LOG_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Broadcasting
BROADCAST_CONNECTION=log

# Filesystem
FILESYSTEM_DISK=s3

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-app-storage-bucket
AWS_USE_PATH_STYLE_ENDPOINT=false

# Vite (for production asset URLs)
VITE_APP_NAME="${APP_NAME}"
VITE_APP_ENV="${APP_ENV}"

# Laravel Octane
OCTANE_SERVER=frankenphp
OCTANE_HTTPS=true
OCTANE_HOST=0.0.0.0
OCTANE_PORT=443
OCTANE_WORKERS=auto
OCTANE_TASK_WORKERS=auto
OCTANE_WATCH=false

# FrankenPHP
FRANKENPHP_CONFIG_PATH=/etc/frankenphp/Caddyfile

# ACME/Let's Encrypt Configuration
ACME_EMAIL=firman@csi-edu.id

# Caddy Admin API (only enable if needed and properly secured)
CADDY_ADMIN_ENABLED=false
CADDY_API_URL=http://localhost:2019
CADDY_API_TIMEOUT=30

# Security Headers
SECURE_HEADERS=true
HSTS_MAX_AGE=31536000
CSP_ENABLED=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Monitoring & Health Checks
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=true

# Backup
BACKUP_ENABLED=true
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_SCHEDULE="0 2 * * *"

# Telescope (disable in production unless needed)
TELESCOPE_ENABLED=false

# Horizon (if using Redis queues)
HORIZON_ENABLED=true
HORIZON_PREFIX=horizon_prod:

# Trusted Proxies (for load balancers)
TRUSTED_PROXIES="*"
TRUSTED_HOSTS="your-domain.com,www.your-domain.com"

# Asset URL (CDN)
ASSET_URL=https://cdn.your-domain.com

# API Rate Limiting
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=60

# CORS
CORS_ALLOWED_ORIGINS="https://your-domain.com,https://www.your-domain.com"
CORS_ALLOWED_METHODS="GET,POST,PUT,DELETE,OPTIONS"
CORS_ALLOWED_HEADERS="Content-Type,Authorization,X-Requested-With"

# Sanctum
SANCTUM_STATEFUL_DOMAINS="your-domain.com,www.your-domain.com"
SESSION_DOMAIN=.your-domain.com