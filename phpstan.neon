includes:
    - vendor/nunomaduro/larastan/extension.neon

parameters:
    level: 5
    paths:
        - app
    excludePaths:
        - app/Console/Kernel.php (?)
        - app/Exceptions/Handler.php (?)
        - app/Http/Kernel.php (?)
        - bootstrap
        - storage
        - vendor
    tmpDir: storage/phpstan
    reportUnmatchedIgnoredErrors: false