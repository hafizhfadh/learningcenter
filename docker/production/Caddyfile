# Caddy Configuration for SaaS Multi-Domain Routing
# Production deployment with FrankenPHP and Laravel Octane

{
    # Global options
    admin off
    persist_config off
    auto_https on
    
    # Enable HTTP/3
    servers {
        protocols h1 h2 h3
    }
    
    # Logging configuration
    log {
        output file /var/log/caddy/access.log {
            roll_size 100mb
            roll_keep 5
            roll_keep_for 720h
        }
        format json
        level INFO
    }
    
    # Error logging
    log error {
        output file /var/log/caddy/error.log {
            roll_size 100mb
            roll_keep 5
            roll_keep_for 720h
        }
        format json
        level ERROR
    }
}

# Main application domain (primary SaaS domain)
{$APP_DOMAIN:learningcenter.app} {
    # Enable automatic HTTPS
    tls {
        protocols tls1.2 tls1.3
    }
    
    # Security headers
    header {
        # HSTS
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        
        # Content Security Policy
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' wss:; frame-ancestors 'none';"
        
        # Other security headers
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        
        # Remove server information
        -Server
        -X-Powered-By
    }
    
    # Rate limiting
    rate_limit {
        zone dynamic_ip {
            key {remote_host}
            events 100
            window 1m
        }
        zone static_content {
            key {remote_host}
            events 500
            window 1m
        }
    }
    
    # Handle static assets with caching
    @static {
        path *.css *.js *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.webp *.avif
    }
    
    handle @static {
        header Cache-Control "public, max-age=31536000, immutable"
        header Vary "Accept-Encoding"
        file_server {
            root /app/public
            precompressed gzip br
        }
    }
    
    # Health check endpoint
    handle /health {
        respond "OK" 200
    }
    
    # Metrics endpoint (protected)
    handle /metrics {
        @authorized {
            header Authorization "Bearer {$METRICS_TOKEN}"
        }
        handle @authorized {
            reverse_proxy localhost:8000
        }
        handle {
            respond "Unauthorized" 401
        }
    }
    
    # Main application
    handle {
        # Enable compression
        encode gzip br
        
        # Set Laravel-specific headers
        header X-Forwarded-Proto "https"
        header X-Forwarded-For {remote_host}
        
        # Reverse proxy to Laravel Octane
        reverse_proxy localhost:8000 {
            # Health check
            health_uri /health
            health_interval 30s
            health_timeout 10s
            
            # Load balancing (for multiple workers)
            lb_policy round_robin
            
            # Timeouts
            transport http {
                dial_timeout 5s
                response_header_timeout 30s
                read_timeout 60s
                write_timeout 60s
            }
            
            # Headers
            header_up Host {upstream_hostport}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Port {server_port}
        }
    }
    
    # Error handling
    handle_errors {
        @5xx expression `{err.status_code} >= 500`
        handle @5xx {
            respond "Service temporarily unavailable" 503
        }
        
        @4xx expression `{err.status_code} >= 400 && {err.status_code} < 500`
        handle @4xx {
            respond "Page not found" 404
        }
    }
}

# Tenant subdomains (SaaS multi-tenancy)
*.{$APP_DOMAIN:learningcenter.app} {
    # Extract subdomain for tenant identification
    @tenant {
        header_regexp subdomain Host ^([^.]+)\.
    }
    
    # Security headers (same as main domain)
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' wss:; frame-ancestors 'none';"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        -X-Powered-By
    }
    
    # Rate limiting for tenants
    rate_limit {
        zone tenant_ip {
            key {remote_host}
            events 200
            window 1m
        }
    }
    
    # Static assets (same as main domain)
    @static {
        path *.css *.js *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.webp *.avif
    }
    
    handle @static {
        header Cache-Control "public, max-age=31536000, immutable"
        file_server {
            root /app/public
            precompressed gzip br
        }
    }
    
    # Tenant application routing
    handle {
        encode gzip br
        
        # Pass tenant information to Laravel
        header X-Tenant-Domain {host}
        header X-Tenant-Subdomain {re.subdomain.1}
        header X-Forwarded-Proto "https"
        header X-Forwarded-For {remote_host}
        
        reverse_proxy localhost:8000 {
            health_uri /health
            health_interval 30s
            health_timeout 10s
            
            transport http {
                dial_timeout 5s
                response_header_timeout 30s
                read_timeout 60s
                write_timeout 60s
            }
            
            header_up Host {upstream_hostport}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Tenant-Domain {host}
            header_up X-Tenant-Subdomain {re.subdomain.1}
        }
    }
}

# Custom domains for enterprise tenants
{$CUSTOM_DOMAINS} {
    # Custom domain handling
    @custom_domain {
        header_regexp domain Host ^([^.]+\.[^.]+)$
    }
    
    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' wss:; frame-ancestors 'none';"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        -X-Powered-By
    }
    
    # Static assets
    @static {
        path *.css *.js *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.webp *.avif
    }
    
    handle @static {
        header Cache-Control "public, max-age=31536000, immutable"
        file_server {
            root /app/public
            precompressed gzip br
        }
    }
    
    # Custom domain routing
    handle {
        encode gzip br
        
        header X-Custom-Domain {host}
        header X-Forwarded-Proto "https"
        header X-Forwarded-For {remote_host}
        
        reverse_proxy localhost:8000 {
            health_uri /health
            health_interval 30s
            health_timeout 10s
            
            header_up Host {upstream_hostport}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Custom-Domain {host}
        }
    }
}

# Admin panel subdomain (optional)
admin.{$APP_DOMAIN:learningcenter.app} {
    # Enhanced security for admin panel
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none';"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        -X-Powered-By
    }
    
    # Stricter rate limiting for admin
    rate_limit {
        zone admin_ip {
            key {remote_host}
            events 50
            window 1m
        }
    }
    
    # Admin panel routing
    handle {
        encode gzip br
        
        header X-Admin-Panel "true"
        header X-Forwarded-Proto "https"
        
        reverse_proxy localhost:8000 {
            health_uri /health
            health_interval 30s
            health_timeout 10s
            
            header_up Host {upstream_hostport}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Admin-Panel "true"
        }
    }
}