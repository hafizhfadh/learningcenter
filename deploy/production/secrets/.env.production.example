APP_ENV=production
APP_DEBUG=false

# Laravel Octane
OCTANE_SERVER=frankenphp
OCTANE_HTTPS=true
OCTANE_HOST=0.0.0.0
OCTANE_HTTP_PORT=80
OCTANE_PORT=443
OCTANE_WORKERS=auto
OCTANE_TASK_WORKERS=auto
OCTANE_MAX_REQUESTS=250

# FrankenPHP runtime defaults
OCTANE_FRANKENPHP_WORKERS=auto
OCTANE_FRANKENPHP_ADMIN_PORT=2019
OCTANE_FRANKENPHP_HTTPS=true
OCTANE_FRANKENPHP_HTTP_REDIRECT=true
OCTANE_FRANKENPHP_CADDYFILE=/etc/frankenphp/Caddyfile

# Backwards compatibility for legacy deployments
FRANKENPHP_CONFIG_PATH=/etc/frankenphp/Caddyfile
