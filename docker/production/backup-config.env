# Learning Center Backup Configuration
# Environment variables for backup and disaster recovery systems

# Backup Configuration
BACKUP_BASE_DIR=/var/backups/learning-center
RETENTION_DAYS=30
COMPRESSION_LEVEL=6
BACKUP_SCHEDULE_FULL="0 2 * * 0"    # Weekly full backup at 2 AM Sunday
BACKUP_SCHEDULE_INCREMENTAL="0 2 * * 1-6"  # Daily incremental backup at 2 AM Mon-Sat
BACKUP_SCHEDULE_DATABASE="0 */6 * * *"     # Database backup every 6 hours

# Encryption Configuration
ENCRYPTION_ENABLED=true
ENCRYPTION_KEY_FILE=/etc/learning-center/backup-encryption.key
ENCRYPTION_ALGORITHM=AES256

# Remote Storage Configuration
S3_ENABLED=false
S3_BUCKET=learning-center-backups
S3_PREFIX=production
S3_REGION=us-east-1
S3_STORAGE_CLASS=STANDARD_IA
S3_LIFECYCLE_ENABLED=true

# Azure Blob Storage (alternative to S3)
AZURE_ENABLED=false
AZURE_STORAGE_ACCOUNT=learningcenterbackups
AZURE_CONTAINER=backups
AZURE_SAS_TOKEN=

# Google Cloud Storage (alternative to S3/Azure)
GCS_ENABLED=false
GCS_BUCKET=learning-center-backups
GCS_PROJECT_ID=learning-center-prod
GCS_KEY_FILE=/etc/learning-center/gcs-service-account.json

# Database Backup Configuration
POSTGRES_BACKUP_FORMAT=custom  # custom, plain, tar
POSTGRES_COMPRESSION=true
POSTGRES_JOBS=4  # Parallel jobs for pg_dump
REDIS_BACKUP_TYPE=rdb  # rdb, aof
REDIS_SAVE_BEFORE_BACKUP=true

# Application Backup Configuration
APP_BACKUP_EXCLUDE_PATTERNS="*.log,*.tmp,node_modules,vendor,.git,storage/framework/cache"
APP_BACKUP_INCLUDE_STORAGE=true
APP_BACKUP_INCLUDE_UPLOADS=true
APP_BACKUP_INCLUDE_CONFIGS=true

# Monitoring and Alerting
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
WEBHOOK_ENABLED=false
EMAIL_ALERTS_ENABLED=false
ALERT_EMAIL=admin@learningcenter.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# Emergency Contacts
EMERGENCY_WEBHOOK_URL=https://emergency.webhook.url/learning-center
EMERGENCY_EMAIL=emergency@learningcenter.com
EMERGENCY_SMS_API=https://api.twilio.com/2010-04-01/Accounts/YOUR_ACCOUNT/Messages.json
EMERGENCY_PHONE=+1234567890

# Disaster Recovery Configuration
DR_ENABLED=true
DR_CONFIG_FILE=/etc/learning-center/disaster-recovery.conf
RECOVERY_LOG_FILE=/var/log/learning-center-recovery.log
SECONDARY_SERVER=dr.learningcenter.com
FAILOVER_TIMEOUT=300  # seconds
HEALTH_CHECK_INTERVAL=60  # seconds
HEALTH_CHECK_RETRIES=3

# Backup Validation
VALIDATION_ENABLED=true
VALIDATION_SCHEDULE="0 4 * * 1"  # Weekly validation on Monday at 4 AM
VALIDATION_SAMPLE_SIZE=3  # Number of recent backups to validate
CHECKSUM_VERIFICATION=true
RESTORE_TEST_ENABLED=false  # Enable for periodic restore testing

# Performance Configuration
BACKUP_NICE_LEVEL=10  # Lower priority for backup processes
BACKUP_IONICE_CLASS=2  # Best effort I/O scheduling
BACKUP_IONICE_LEVEL=7  # Lowest priority within class
PARALLEL_COMPRESSION=true
COMPRESSION_THREADS=2

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARN, ERROR
LOG_ROTATION=true
LOG_MAX_SIZE=100M
LOG_MAX_FILES=10
SYSLOG_ENABLED=true
SYSLOG_FACILITY=local0

# Security Configuration
BACKUP_FILE_PERMISSIONS=600
BACKUP_DIR_PERMISSIONS=700
SECURE_DELETE=true  # Use shred for file deletion
AUDIT_LOGGING=true
ACCESS_CONTROL_ENABLED=true

# Cloud Provider Specific Settings
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=default

# Azure
AZURE_STORAGE_CONNECTION_STRING=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=/etc/learning-center/gcs-service-account.json

# Backup Retention Policies
DAILY_RETENTION=7    # Keep daily backups for 7 days
WEEKLY_RETENTION=4   # Keep weekly backups for 4 weeks
MONTHLY_RETENTION=12 # Keep monthly backups for 12 months
YEARLY_RETENTION=3   # Keep yearly backups for 3 years

# Advanced Configuration
BACKUP_LOCK_FILE=/var/run/learning-center-backup.lock
BACKUP_PID_FILE=/var/run/learning-center-backup.pid
BACKUP_STATUS_FILE=/var/run/learning-center-backup.status
CONCURRENT_BACKUPS=false
BACKUP_BANDWIDTH_LIMIT=0  # KB/s, 0 = unlimited
BACKUP_CPU_LIMIT=50  # Percentage

# Testing and Development
TEST_MODE=false
DRY_RUN=false
VERBOSE_OUTPUT=false
DEBUG_MODE=false