{
    # Global options
    http_port 80
    https_port 443

    # Enable HTTP/1.1, HTTP/2 and HTTP/3
    servers {
        protocols h1 h2 h3  # note the plural “protocols”:contentReference[oaicite:1]{index=1}
    }

    # Disable the admin API in production for security
    admin off

    # Structured JSON logging to stdout (Docker-friendly)
    log {
        output stdout
        format json
        level info
    }
}

# Main site (use your domain here; no http:// or https://)
learning.csi-academy.id {
    # Compress responses
    encode zstd gzip

    # Serve static assets with long caching
    @assets {
        path *.ico *.css *.js *.png *.jpg *.jpeg *.svg *.webp *.gif *.woff *.woff2 *.ttf *.eot *.otf
        path /build/* /assets/*
    }
    handle @assets {
        root * /app/public
        file_server
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # Fallback to Laravel (FrankenPHP handles PHP)
    handle {
        root * /app/public
        try_files {path} {path}/ /index.php?{query}
        php {
            root /app/public
        }
    }

    # HTTP→HTTPS redirect happens automatically via Caddy’s auto_https mechanism
}
