{
	frankenphp
	admin off
	persist_config off
	storage file_system {
		root /var/www/html/storage/caddy
	}
	# Ensure php_server runs before file_server
	order php_server before file_server
}

:9000 {
	# Site root
	root * /var/www/html/public

	# Compression
	encode zstd br gzip

	# Serve PHP with FrankenPHP
	php_server {
		# Explicit root for better caching
		root /var/www/html/public

		# Pass common environment variables through
		env APP_ENV {$APP_ENV}
		env APP_DEBUG {$APP_DEBUG}
		env APP_URL {$APP_URL}
		env OCTANE_WORKERS {$OCTANE_WORKERS}
		env OCTANE_MAX_REQUESTS {$OCTANE_MAX_REQUESTS}
		env OCTANE_TASK_WORKERS {$OCTANE_TASK_WORKERS}

		# Laravel Octane FrankenPHP worker
		worker /var/www/html/public/frankenphp-worker.php {$OCTANE_WORKERS}
	}

	# Static assets
	file_server
}
