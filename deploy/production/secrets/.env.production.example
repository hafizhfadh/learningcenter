APP_NAME="Learning Center"
APP_ENV=production
APP_KEY=base64:change-me
APP_URL=https://learning.csi-academy.id
APP_HOST=learning.csi-academy.id
APP_IMAGE=ghcr.io/hafizhfadh/learningcenter:latest
SESSION_LIFETIME=120
SESSION_COOKIE=learningcenter_session
CACHE_PREFIX=learningcenter

DB_HOST=10.0.0.10
DB_PORT=5432
DB_DATABASE=learningcenter
DB_USERNAME=learningcenter_app
DB_PASSWORD=change-me

REDIS_HOST=10.0.0.11
REDIS_PORT=6379
REDIS_PASSWORD=change-me

MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=postmaster@csi-academy.id
MAIL_PASSWORD=change-me
MAIL_FROM_ADDRESS=no-reply@csi-academy.id
MAIL_FROM_NAME="Learning Center"

CF_DNS_API_TOKEN=change-me
TRAEFIK_ACME_EMAIL=admin@csi-academy.id
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_DOCKER_NETWORK=learningcenter_services
RUN_MIGRATIONS=1
HEALTH_TIMEOUT_SECONDS=180

SENTRY_LARAVEL_DSN=
OCTANE_WORKERS=4
OCTANE_TASK_WORKERS=2
OCTANE_MAX_REQUESTS=500
OCTANE_LISTEN=tcp://0.0.0.0:9000
OCTANE_HOST=0.0.0.0
OCTANE_PORT=9000
OCTANE_FRANKENPHP_ADMIN_PORT=2019
OCTANE_FRANKENPHP_HTTP_REDIRECT=true
HORIZON_TRIES=3
HORIZON_SUPERVISOR_MEMORY_LIMIT=256
