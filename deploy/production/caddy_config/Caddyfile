{
  email {$CADDY_GLOBAL_EMAIL}
  acme_dns cloudflare {$CLOUDFLARE_API_TOKEN}
  on_demand_tls {
    ask {$CADDY_ON_DEMAND_ENDPOINT}
    interval 2m
    burst 5
  }
  log {
    output stdout
    format json
    level INFO
  }
  admin off
}

(common_settings) {
  encode zstd gzip
  header {
    Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), usb=()"
    Content-Security-Policy "upgrade-insecure-requests"
  }
  tls {
    dns cloudflare {$CLOUDFLARE_API_TOKEN}
  }
  reverse_proxy app:9000 {
    fail_timeout 5s
    health_uri /health
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Forwarded-For {remote_host}
    transport http {
      dial_timeout 5s
      read_timeout 60s
      write_timeout 60s
    }
  }
  log {
    output stdout
    format json
  }
}

(admin.csi-academy.id) {
  import common_settings
}

(learning.csi-academy.id) {
  import common_settings
}

*.csi-academy.id {
  import common_settings
}

*.nf-testingcenter.org {
  import common_settings
}
