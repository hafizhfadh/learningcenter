# Production Environment Configuration
# Copy this file to .env.production and update the values

# Application
APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_DOMAIN=yourdomain.com

# External Database Configuration (PostgreSQL Server)
DB_CONNECTION=pgsql
DB_HOST=your-postgres-server.example.com
DB_PORT=5432
DB_DATABASE=laravel_production
DB_USERNAME=laravel
DB_PASSWORD=your-secure-database-password
DB_SSLMODE=require

# External Redis Configuration (Redis Server)
REDIS_HOST=your-redis-server.example.com
REDIS_PASSWORD=your-secure-redis-password
REDIS_PORT=6379
REDIS_DB=0

# Cache Configuration
CACHE_DRIVER=redis
CACHE_PREFIX=laravel_cache

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIES=true

# Queue Configuration
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

# Broadcasting
BROADCAST_DRIVER=redis
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Filesystem
FILESYSTEM_DISK=local

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Laravel Octane Configuration
OCTANE_SERVER=frankenphp
OCTANE_WORKERS=4
OCTANE_TASK_WORKERS=6
OCTANE_MAX_REQUESTS=500
OCTANE_HTTPS=true

# FrankenPHP Configuration
FRANKENPHP_CONFIG="worker ./public/index.php"

# Horizon Configuration
HORIZON_BALANCE_STRATEGY=auto
HORIZON_BALANCE_COOLDOWN=3
HORIZON_BALANCE_MAX_SHIFT=1
HORIZON_FAST_TERMINATION=false

# Security
BCRYPT_ROUNDS=12
HASH_VERIFY=true

# Telescope (disable in production)
TELESCOPE_ENABLED=false

# Debugbar (disable in production)
DEBUGBAR_ENABLED=false

# SSL/TLS Configuration
FORCE_HTTPS=true
SECURE_COOKIES=true

# Rate Limiting
THROTTLE_REQUESTS=60
THROTTLE_DECAY_MINUTES=1

# Caddy Configuration
CADDY_ADMIN_API=0.0.0.0:2019
CADDY_UPSTREAM_HOST=app
CADDY_UPSTREAM_PORT=8000
CADDY_ACME_EMAIL=admin@yourdomain.com

# Node-level Nginx Configuration (configured directly on server)
# NGINX_WORKER_PROCESSES=auto
# NGINX_WORKER_CONNECTIONS=4096

# SSL Configuration (handled by node-level Nginx)
# SSL certificates are managed directly on the server nodes
# CERTBOT_EMAIL=admin@yourdomain.com

# Monitoring and Logging
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Performance Monitoring
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME="${APP_NAME}"

# Docker Configuration
PHP_VERSION=8.3
COMPOSER_VERSION=2.6

# Backup Configuration
BACKUP_DISK=s3
BACKUP_NOTIFICATION_MAIL=admin@yourdomain.com

# Health Check Configuration
HEALTH_CHECK_URL=/health
HEALTH_CHECK_SECRET=

# Feature Flags
FEATURE_REGISTRATION=true
FEATURE_API=true
FEATURE_WEBSOCKETS=true

# API Configuration
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=60

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_ONLY=false

# Additional Security Headers
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true