{
	# Global options for production
	admin off
	auto_https off
	
	# Security headers
	servers {
		protocols h1 h2 h3
	}

	# FrankenPHP configuration
	frankenphp {
		worker {
			file "/app/public/frankenphp-worker.php"
			num 4
		}
	}
}

# Production server configuration
:8080 {
	# Logging configuration
	log {
		level ERROR
		output file /var/log/security/access.log {
			roll_size 100mb
			roll_keep 5
		}
		format json
	}

	# Security headers
	header {
		# Security headers
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; media-src 'self'; object-src 'none'; child-src 'none'; frame-src 'none'; worker-src 'none'; frame-ancestors 'none'; form-action 'self'; base-uri 'self';"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), speaker=(), vibrate=(), fullscreen=(), sync-xhr=()"
		
		# Remove server information
		-Server
		-X-Powered-By
	}

	# Rate limiting
	rate_limit {
		zone static {
			key {remote_host}
			events 100
			window 1m
		}
	}

	# Main route
	route {
		root * "/app/public"
		
		# Enable compression
		encode {
			zstd
			br 6
			gzip 6
		}

		# Handle static assets with caching
		@static {
			file
			path *.css *.js *.ico *.png *.jpg *.jpeg *.gif *.svg *.woff *.woff2 *.ttf *.eot *.webp *.avif
		}
		handle @static {
			header Cache-Control "public, max-age=31536000, immutable"
			file_server
		}

		# Handle storage symlink
		@storage {
			path /storage/*
		}
		handle @storage {
			header Cache-Control "public, max-age=86400"
			file_server
		}

		# PHP application
		php_server {
			index frankenphp-worker.php
			try_files {path} frankenphp-worker.php
			resolve_root_symlink
		}
	}

	# Health check endpoint
	handle /health {
		respond "OK" 200
	}

	# Error handling
	handle_errors {
		@5xx expression {http.error.status_code} >= 500
		handle @5xx {
			respond "Internal Server Error" 500
		}
		
		@4xx expression {http.error.status_code} >= 400
		handle @4xx {
			respond "Not Found" 404
		}
	}
}

# HTTPS server configuration (if needed)
:8443 {
	# TLS configuration for production
	tls internal {
		protocols tls1.2 tls1.3
	}

	# Same configuration as HTTP but with HTTPS
	log {
		level ERROR
		output file /var/log/security/access.log {
			roll_size 100mb
			roll_keep 5
		}
		format json
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; media-src 'self'; object-src 'none'; child-src 'none'; frame-src 'none'; worker-src 'none'; frame-ancestors 'none'; form-action 'self'; base-uri 'self';"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), speaker=(), vibrate=(), fullscreen=(), sync-xhr=()"
		-Server
		-X-Powered-By
	}

	route {
		root * "/app/public"
		encode zstd br gzip

		@static {
			file
			path *.css *.js *.ico *.png *.jpg *.jpeg *.gif *.svg *.woff *.woff2 *.ttf *.eot *.webp *.avif
		}
		handle @static {
			header Cache-Control "public, max-age=31536000, immutable"
			file_server
		}

		@storage {
			path /storage/*
		}
		handle @storage {
			header Cache-Control "public, max-age=86400"
			file_server
		}

		php_server {
			index frankenphp-worker.php
			try_files {path} frankenphp-worker.php
			resolve_root_symlink
		}
	}

	handle /health {
		respond "OK" 200
	}

	handle_errors {
		@5xx expression {http.error.status_code} >= 500
		handle @5xx {
			respond "Internal Server Error" 500
		}
		
		@4xx expression {http.error.status_code} >= 400
		handle @4xx {
			respond "Not Found" 404
		}
	}
}